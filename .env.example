# Signet — environment template. Copy to `.env` (gitignored) and fill in.
# NOTHING here is ever committed; the agent never reads or uses these values.

# --- Sepolia (owner-run deploy + round-trip only) ---
# MUST be an eth-sepolia endpoint. A mainnet URL will be rejected by the
# chainId gate in every script.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-key>

# Operator wallet (deployer + issuer + disperse sender). Holds the test ETH.
SEPOLIA_PRIVATE_KEY=0x...

# For scripts/sepolia-roundtrip.mjs: the key of ONE recipient wallet
# (so the script can prove the recipient-side decrypt) and optionally a
# distinct verifier key (defaults to the operator).
RECIPIENT_PRIVATE_KEY=0x...
VERIFIER_PRIVATE_KEY=0x...

# --- Frontend (public, baked into the client bundle at build time) ---
# Used for reads + the wallet transport on Sepolia. Use a rate-limited,
# browser-safe key here — it is visible to anyone who opens the site.
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-key>
